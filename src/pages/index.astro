---
import '../styles/global.css';
const base = import.meta.env.BASE_URL;
const feedUrl = `${base.replace(/\/$/, '')}/osint.json`;
const site = 'https://jessn-dev.github.io/osint-atlas/';
const desc =
  'Graph-first, link-health-aware map of OSINT resources — searchable, grouped, with dead-link archiving.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={desc} />
    <meta name="keywords" content="OSINT, cheat sheet, tools, SOCMINT, GEOINT, recon, intelligence" />
    <meta name="theme-color" content="#06080f" />
    <link rel="canonical" href={site} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="OSINT Atlas" />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={site} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="OSINT Atlas" />
    <meta name="twitter:description" content={desc} />

    <title>OSINT Atlas</title>
  </head>
  <body>
    <header class="topbar">
      <h1>OSINT <b>Atlas</b></h1>
      <input
        id="search"
        type="search"
        placeholder="Search tools, categories, tags…"
        autocomplete="off"
        aria-label="search"
      />
      <div id="statusfilter" class="statusfilter" role="group" aria-label="filter by link status"></div>
      <span class="stats" id="stats" aria-live="polite"></span>
    </header>

    <div id="chips" class="chips" role="group" aria-label="filter by group"></div>
    <div id="legend" class="legend" aria-hidden="true"></div>
    <div class="hint">
      click group → category → tools · "+more" loads more · double-click opens · scroll to zoom
    </div>

    <aside class="panel" id="panel" role="complementary" aria-label="details">
      <button class="close" id="panel-close" aria-label="close panel">×</button>
      <div id="panel-body"></div>
    </aside>

    <main id="app"><svg role="img" aria-label="OSINT resource graph"></svg></main>

    <script define:vars={{ feedUrl }}>
      window.__FEED_URL__ = feedUrl;
    </script>
    <script src="../lib/bootstrap.ts"></script>
  </body>
</html>
