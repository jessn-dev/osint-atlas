{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src", "scripts", "data", "*.mjs"],
  "exclude": ["node_modules", "dist"]
}
